{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amxv.dev/schemas/model-qualification-catalog-v2.schema.json",
  "title": "Model Qualification Catalog V2",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generatedAt", "policy", "qualificationStates", "supportStates", "recipes"],
  "properties": {
    "version": { "const": "2.0.0" },
    "generatedAt": { "type": "string", "format": "date" },
    "policy": { "type": "string", "minLength": 1 },
    "qualificationStates": {
      "const": ["configured", "smokeAuthorized", "smokePassed", "qualified"]
    },
    "supportStates": { "const": ["unavailable", "experimental", "supported"] },
    "recipes": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "modelId",
          "revision",
          "license",
          "architecture",
          "qualification",
          "support",
          "firstWaveExecutable",
          "blockers"
        ],
        "properties": {
          "id": { "type": "string" },
          "modelId": { "type": "string" },
          "revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
          "license": { "type": "string" },
          "architecture": { "type": "string" },
          "qualification": { "const": "configured" },
          "support": { "const": "experimental" },
          "firstWaveExecutable": { "type": "boolean" },
          "blockers": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    }
  }
}
