{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amxv.dev/schemas/model-qualification-v2.schema.json",
  "title": "Model Qualification Recipe V2",
  "type": "object",
  "required": [
    "recipeSchemaVersion",
    "id",
    "track",
    "modelId",
    "revision",
    "license",
    "architecture",
    "qualification",
    "optimization",
    "blockers",
    "runtime"
  ],
  "properties": {
    "recipeSchemaVersion": { "const": "2.0.0" },
    "id": { "type": "string", "minLength": 1 },
    "track": { "enum": ["chat", "embedding"] },
    "modelId": { "type": "string", "minLength": 3 },
    "revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "license": { "type": "object", "required": ["spdx", "pinnedArtifact", "note"] },
    "architecture": { "type": "object", "required": ["family", "modelType", "remoteCode", "customKernels"] },
    "qualification": {
      "type": "object",
      "required": ["state", "supportState", "firstWaveExecutable"],
      "properties": {
        "state": { "const": "configured" },
        "supportState": { "const": "unavailable" },
        "firstWaveExecutable": { "type": "boolean" }
      }
    },
    "optimization": {
      "type": "object",
      "required": ["methods", "targetModules", "targetParameters", "modulesToSave", "frozen"]
    },
    "blockers": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "runtime": { "type": "object", "required": ["gpu", "vramGiB", "storageGiB", "image", "distributed"] }
  },
  "additionalProperties": false
}
