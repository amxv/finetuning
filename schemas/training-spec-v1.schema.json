{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amxv.dev/finetuning/training-spec-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["trainingSpecVersion", "runId", "dataset", "recipeId", "outputDirectory", "objective", "seed"],
  "properties": {
    "trainingSpecVersion": { "const": "1.0.0" },
    "qualificationSchemaVersion": { "const": "2.0.0" },
    "runId": { "type": "string", "minLength": 1 },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifestPath", "recordsHash"],
      "properties": {
        "manifestPath": { "type": "string" },
        "recordsHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "recipeId": { "type": "string" },
    "outputDirectory": { "type": "string" },
    "objective": { "const": "sft" },
    "seed": { "type": "integer", "minimum": 0 },
    "operation": { "enum": ["prepare", "run", "resume", "status", "evaluate", "export"] },
    "checkpointPath": { "type": "string" },
    "quantization": { "enum": ["4bit", "8bit", "bf16"] },
    "adapter": { "enum": ["lora", "qlora", "full"] },
    "trustRemoteCode": { "type": "boolean" },
    "executionGates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowModelLoad", "licenseApproved", "revisionPinned", "remoteCodeReviewed", "gpuQualified"],
      "properties": {
        "allowModelLoad": { "type": "boolean" },
        "licenseApproved": { "type": "boolean" },
        "revisionPinned": { "type": "boolean" },
        "remoteCodeReviewed": { "type": "boolean" },
        "gpuQualified": { "type": "boolean" },
        "experimentalExecutionApproved": { "type": "boolean" },
        "stagingNetworkApproved": { "type": "boolean" },
        "downloadsApproved": { "type": "boolean" },
        "remoteCodeApproved": { "type": "boolean" },
        "gpuApproved": { "type": "boolean" },
        "budgetApproved": { "type": "boolean" },
        "datasetRightsApproved": { "type": "boolean" },
        "modelLicenseAccepted": { "type": "boolean" },
        "uploadRequested": { "type": "boolean" },
        "uploadApproved": { "type": "boolean" },
        "architectureEvidenceApproved": { "type": "boolean" },
        "frameworkEvidenceApproved": { "type": "boolean" },
        "customKernelApproved": { "type": "boolean" }
      }
    },
    "qualificationAuthorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "recipeId",
        "recipeIdentityHash",
        "evidenceDigest",
        "sequence",
        "dischargedBlockers",
        "storePath",
        "storeSha256",
        "trustPolicySha256",
        "expiresAt",
        "architectureEvidenceSha256",
        "operationClass",
        "operation",
        "outputDirectory",
        "artifactSha256",
        "evidenceBindings",
        "signerKeyId",
        "authorizationSignatureBase64"
      ],
      "properties": {
        "state": { "enum": ["smokeAuthorized", "smokePassed", "qualified"] },
        "recipeId": { "type": "string" },
        "recipeIdentityHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "evidenceDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "sequence": { "type": "integer", "minimum": 1 },
        "dischargedBlockers": { "type": "array", "items": { "type": "string" } },
        "storePath": { "type": "string" },
        "storeSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "trustPolicySha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "architectureEvidenceSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "operationClass": { "enum": ["mechanicsSmoke", "qualificationRun", "experimentalUse"] },
        "operation": { "enum": ["run", "resume", "evaluate", "export"] },
        "outputDirectory": { "type": "string" },
        "artifactSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "evidenceBindings": { "$ref": "qualification-evidence-v2.schema.json#/$defs/bindings" },
        "signerKeyId": { "type": "string" },
        "authorizationSignatureBase64": { "type": "string", "minLength": 32 }
      },
      "allOf": [
        {
          "if": { "properties": { "state": { "const": "smokeAuthorized" } }, "required": ["state"] },
          "then": {
            "properties": {
              "operationClass": { "const": "mechanicsSmoke" },
              "operation": { "enum": ["run", "resume"] }
            }
          }
        },
        {
          "if": { "properties": { "state": { "const": "smokePassed" } }, "required": ["state"] },
          "then": {
            "properties": {
              "operationClass": { "const": "qualificationRun" },
              "operation": { "enum": ["run", "resume", "evaluate", "export"] }
            }
          }
        },
        {
          "if": { "properties": { "state": { "const": "qualified" } }, "required": ["state"] },
          "then": {
            "properties": {
              "operationClass": { "const": "experimentalUse" },
              "operation": { "enum": ["evaluate", "export"] }
            }
          }
        }
      ]
    },
    "recipeIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modelRevision", "tokenizerRevision"],
      "properties": {
        "modelRevision": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "tokenizerRevision": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "templateHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "reasoningPolicy": { "type": "string" }
      }
    },
    "trainingArguments": { "type": "object" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "qualificationSchemaVersion": { "const": "2.0.0" } },
        "required": ["qualificationSchemaVersion"]
      },
      "then": {
        "required": ["executionGates", "qualificationAuthorization"],
        "properties": {
          "executionGates": {
            "required": [
              "allowModelLoad",
              "licenseApproved",
              "revisionPinned",
              "remoteCodeReviewed",
              "gpuQualified",
              "experimentalExecutionApproved",
              "stagingNetworkApproved",
              "downloadsApproved",
              "remoteCodeApproved",
              "gpuApproved",
              "budgetApproved",
              "datasetRightsApproved",
              "modelLicenseAccepted",
              "uploadRequested",
              "uploadApproved",
              "architectureEvidenceApproved",
              "frameworkEvidenceApproved",
              "customKernelApproved"
            ]
          }
        }
      }
    }
  ]
}
