{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amxv.dev/schemas/qualification-store-v2.schema.json",
  "title": "Qualification Promotion Store V2",
  "type": "object",
  "additionalProperties": false,
  "required": ["storeVersion", "trustPolicySha256", "recipes"],
  "properties": {
    "storeVersion": { "const": "2.0.0" },
    "trustPolicySha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "recipes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["state", "sequence", "currentDigest", "evidenceIds", "evidenceDigests", "acceptedEvidence"],
        "properties": {
          "state": { "enum": ["smokeAuthorized", "smokePassed", "qualified"] },
          "sequence": { "type": "integer", "minimum": 1 },
          "currentDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "evidenceIds": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
          "evidenceDigests": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          },
          "acceptedEvidence": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "qualification-evidence-v2.schema.json" }
          }
        }
      }
    }
  }
}
