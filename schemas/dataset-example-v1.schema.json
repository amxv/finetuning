{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amxv.dev/finetuning/schemas/dataset-example-v1.schema.json",
  "title": "DatasetExampleV1",
  "type": "object",
  "required": ["datasetSchemaVersion", "id", "messages", "provenance", "createdAt"],
  "properties": {
    "datasetSchemaVersion": { "const": "1.0.0" },
    "id": { "type": "string", "minLength": 1 },
    "messages": { "type": "array", "minItems": 1 },
    "provenance": { "type": "object", "required": ["source"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "contentHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "additionalProperties": true
}
