{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "embedding.training.v1",
  "type": "object",
  "required": [
    "embeddingTrainingSpecVersion",
    "runId",
    "datasetManifest",
    "recipeId",
    "objective",
    "outputDirectory",
    "effectiveBatchSize",
    "immutableIdentity"
  ],
  "properties": {
    "embeddingTrainingSpecVersion": { "const": "embedding.training.v1" },
    "qualificationSchemaVersion": { "const": "2.0.0" },
    "runId": { "type": "string", "minLength": 1 },
    "datasetManifest": { "type": "string", "minLength": 1 },
    "recipeId": { "type": "string", "minLength": 1 },
    "objective": { "enum": ["contrastive", "multiple-negatives", "cosine", "margin"] },
    "outputDirectory": { "type": "string", "minLength": 1 },
    "effectiveBatchSize": { "type": "integer", "minimum": 2 },
    "dimension": { "type": "integer", "minimum": 1 },
    "adapter": { "enum": ["lora", "full"] },
    "trustRemoteCode": { "type": "boolean" },
    "executionGates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowModelLoad", "licenseApproved", "revisionPinned", "remoteCodeReviewed", "gpuQualified"],
      "properties": {
        "allowModelLoad": { "type": "boolean" },
        "licenseApproved": { "type": "boolean" },
        "revisionPinned": { "type": "boolean" },
        "remoteCodeReviewed": { "type": "boolean" },
        "gpuQualified": { "type": "boolean" },
        "experimentalExecutionApproved": { "type": "boolean" },
        "stagingNetworkApproved": { "type": "boolean" },
        "downloadsApproved": { "type": "boolean" },
        "remoteCodeApproved": { "type": "boolean" },
        "gpuApproved": { "type": "boolean" },
        "budgetApproved": { "type": "boolean" },
        "datasetRightsApproved": { "type": "boolean" },
        "modelLicenseAccepted": { "type": "boolean" },
        "uploadRequested": { "type": "boolean" },
        "uploadApproved": { "type": "boolean" },
        "architectureEvidenceApproved": { "type": "boolean" },
        "frameworkEvidenceApproved": { "type": "boolean" },
        "customKernelApproved": { "type": "boolean" }
      }
    },
    "qualificationAuthorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "recipeId",
        "recipeIdentityHash",
        "evidenceDigest",
        "sequence",
        "dischargedBlockers",
        "storePath",
        "storeSha256"
      ],
      "properties": {
        "state": { "const": "smokeAuthorized" },
        "recipeId": { "type": "string" },
        "recipeIdentityHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "evidenceDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "sequence": { "type": "integer", "minimum": 1 },
        "dischargedBlockers": { "type": "array", "items": { "type": "string" } },
        "storePath": { "type": "string" },
        "storeSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "recipeIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modelRevision", "tokenizerRevision"],
      "properties": {
        "modelRevision": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "tokenizerRevision": { "type": "string", "pattern": "^[a-f0-9]{40}$" }
      }
    },
    "trainingArguments": { "type": "object" },
    "seed": { "type": "integer" },
    "immutableIdentity": {
      "type": "object",
      "required": [
        "modelRevision",
        "tokenizerRevision",
        "configRevision",
        "dataHash",
        "splitHash",
        "taskMapping",
        "prompts",
        "pooling",
        "padding",
        "normalization",
        "dimensions",
        "objective",
        "seed"
      ],
      "properties": {
        "modelRevision": { "type": "string", "minLength": 1 },
        "tokenizerRevision": { "type": "string", "minLength": 1 },
        "configRevision": { "type": "string", "minLength": 1 },
        "dataHash": { "type": "string", "minLength": 1 },
        "splitHash": { "type": "string", "minLength": 1 },
        "taskMapping": {},
        "prompts": {},
        "pooling": { "type": "string", "minLength": 1 },
        "padding": { "type": "string", "minLength": 1 },
        "normalization": {},
        "dimensions": { "type": "array", "minItems": 1, "items": { "type": "integer", "minimum": 1 } },
        "objective": { "type": "string", "minLength": 1 },
        "seed": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "allowedRuntimeChanges": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": { "qualificationSchemaVersion": { "const": "2.0.0" } },
        "required": ["qualificationSchemaVersion"]
      },
      "then": {
        "required": ["executionGates", "qualificationAuthorization"],
        "properties": {
          "executionGates": {
            "required": [
              "allowModelLoad",
              "licenseApproved",
              "revisionPinned",
              "remoteCodeReviewed",
              "gpuQualified",
              "experimentalExecutionApproved",
              "stagingNetworkApproved",
              "downloadsApproved",
              "remoteCodeApproved",
              "gpuApproved",
              "budgetApproved",
              "datasetRightsApproved",
              "modelLicenseAccepted",
              "uploadRequested",
              "uploadApproved",
              "architectureEvidenceApproved",
              "frameworkEvidenceApproved",
              "customKernelApproved"
            ]
          }
        }
      }
    }
  ]
}
