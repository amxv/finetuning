---
import BaseLayout from "zuedocs/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { primaryNav, siteConfig } from "../data/docs";

const docs = (await getCollection("docs")).sort((a, b) => a.data.order - b.data.order);

const proofPoints = [
  {
    title: "Chat data and response distillation",
    body: "Freeze canonical conversations, generate or fake teacher responses, enforce budgets and policy, then export versioned training jobs."
  },
  {
    title: "Embedding data and objectives",
    body: "Build retrieval pairs, triplets, scores, rankings, and vector targets with leakage groups, provenance, and late-bound prompts."
  },
  {
    title: "Training, resume, and evaluation",
    body: "Hand strict jobs to the Python trainer, classify checkpoints, compare baselines, and verify every exported artifact by hash."
  },
  {
    title: "Explicit capability gates",
    body: "CPU fixtures run offline. Provider calls, downloads, GPU recipes, remote code, uploads, and RunPod mutation stay explicit or unavailable."
  }
];

const workflows = [
  "Choose Chat for response distillation, tool trajectories, SFT, and adapter evaluation.",
  "Choose Embeddings for retrieval, STS, classification, clustering, hard negatives, and relevance distillation.",
  "Choose offline evaluation to inspect schemas, SDK contracts, checkpoints, metrics, and portable artifacts without a model download.",
  "Share canonical manifests, provider policy, budgets, provenance, split controls, resumability, and compliance across both tracks."
];
---

<BaseLayout
  title={`${siteConfig.name} | ${siteConfig.strapline}`}
  description={siteConfig.description}
  siteConfig={siteConfig}
  primaryNav={primaryNav}
>
  <section class="hero shell">
    <div class="hero__copy">
      <p class="section-label">Fine-tuning workflow toolkit</p>
      <h1>
        Build reproducible chat and embedding models from data to verified artifacts.
      </h1>
      <p class="hero__lede">
        finetuning provides a TypeScript SDK and CLI for canonical data, response and embedding
        distillation, orchestration, evaluation, and artifacts, with a separately packaged Python
        trainer for executable local jobs.
      </p>
      <p class="hero__annotation">
        Start with deterministic CPU fixtures. Provider calls, model downloads, GPU recipes,
        remote code, uploads, and live RunPod mutation remain separately authorized or fail closed.
      </p>
      <div class="hero__actions">
        <a class="button button--solid" href="/docs/quickstart">Start with the quickstart</a>
        <a class="button button--ghost" href="/docs">Browse the docs</a>
      </div>
    </div>
    <aside class="hero__panel">
      <p class="hero__panel-label">Choose a track</p>
      <ul class="hero__signal-list">
        <li>Chat: freeze → distill → train → evaluate → export.</li>
        <li>Embeddings: validate → train/resume → compare → export.</li>
        <li>Framework: inspect contracts, locks, manifests, and hashes offline.</li>
      </ul>
      <div class="hero__terminal">
        <span>$ finetuning distill plan --root tmp/chat-offline/distill --json</span>
        <span>$ finetuning training run --spec examples/chat-offline/training.json</span>
        <span>$ finetuning embed train run --config examples/embedding-offline/training.json</span>
        <span>$ finetuning embed evaluate compare --config examples/embedding-offline/evaluation.json</span>
      </div>
    </aside>
  </section>

  <section class="shell section-grid">
    <div class="section-heading">
      <p class="section-label">What it solves</p>
      <h2>One auditable path from canonical records to evaluation and portable export.</h2>
      <p>
        Data hashes, immutable recipe identity, provider policy, budgets, checkpoints, evaluation
        reports, and artifact manifests remain connected instead of disappearing between scripts.
      </p>
    </div>
    <div class="proof-grid">
      {proofPoints.map((item) => (
        <article class="proof-card">
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="shell split-section">
    <div>
      <p class="section-label">Built for</p>
      <h2>Teams that need repeatable experiments—not a collection of one-off scripts.</h2>
    </div>
    <div class="stack-list">
      {workflows.map((item) => (
        <article class="stack-list__item">
          <p>{item}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="shell capability-band">
    <div class="capability-band__intro">
      <p class="section-label">Available now and gated</p>
      <h2>Offline contracts are runnable; production claims require recorded evidence.</h2>
    </div>
    <div class="capability-band__grid">
      <div>
        <p class="capability-title">available offline</p>
        <p>Canonical schemas, validation, deterministic fixtures, SDK/CLI planning, CPU training, resume, evaluation, and artifact verification.</p>
      </div>
      <div>
        <p class="capability-title">provider opt-in</p>
        <p>OpenAI and Anthropic adapters require an explicit model, credential environment reference, network flag, and positive budget.</p>
      </div>
      <div>
        <p class="capability-title">production gated</p>
        <p>All production chat and embedding recipes remain unavailable until license, hardware, reload, and evaluation evidence passes.</p>
      </div>
      <div>
        <p class="capability-title">remote execution</p>
        <p>RunPod read-only and dry-run contracts exist; live Pod and volume mutation, Serverless, spot, and fleet remain unavailable.</p>
      </div>
    </div>
  </section>

  <section class="shell docs-teaser">
    <div class="section-heading">
      <p class="section-label">Docs map</p>
      <h2>Start with the task you need to complete.</h2>
      <p>
        Follow the runnable Chat or Embeddings tutorial, then use task guides for distillation,
        evaluation, checkpoints, model selection, providers, operations, and security.
      </p>
    </div>
    <div class="docs-teaser__grid">
      {docs.map((entry) => (
        <a class="docs-teaser__card" href={`/docs/${entry.id}`}>
          <span>{entry.data.category}</span>
          <h3>{entry.data.title}</h3>
          <p>{entry.data.summary ?? entry.data.description}</p>
        </a>
      ))}
    </div>
  </section>
  <section class="shell closing-note">
    <p>
      Use finetuning when provenance, reproducibility, evaluation, and honest capability gates
      matter as much as the training command itself.
    </p>
  </section>
</BaseLayout>
