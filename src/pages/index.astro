---
import BaseLayout from "zuedocs/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { primaryNav, siteConfig } from "../data/docs";

const docs = (await getCollection("docs")).sort((a, b) => a.data.order - b.data.order);

const proofPoints = [
  {
    title: "Offline-first workflows",
    body: "Generate personas, simulate datasets, and run local-pseudo translation without provider credentials."
  },
  {
    title: "Tool-calling dataset support",
    body: "Export canonical OpenAI chat fine-tuning JSONL in plain-chat, tool-decision, or full-tool-trajectory mode."
  },
  {
    title: "Validation before training",
    body: "Check JSONL parsing, message roles, tool-call arguments, tool-result references, duplicate IDs, and summary counts."
  },
  {
    title: "Explicit provider paths",
    body: "Switch to OpenAI or Anthropic adapters only when you choose a provider, model, and API key environment variable."
  }
];

const workflows = [
  "Model assistant domains in scenario JSON instead of hard-coding behavior in scripts.",
  "Generate deterministic sample datasets from a clean checkout before adding provider credentials.",
  "Preserve full tool-call loops when the model needs to learn tool choice, tool results, and final responses.",
  "Translate generated datasets while keeping tool calls, tool definitions, metadata, and validation rules intact."
];
---

<BaseLayout
  title={`${siteConfig.name} | ${siteConfig.strapline}`}
  description={siteConfig.description}
  siteConfig={siteConfig}
  primaryNav={primaryNav}
>
  <section class="hero shell">
    <div class="hero__copy">
      <p class="section-label">Scenario-driven dataset toolkit</p>
      <h1>
        Build validated fine-tuning datasets from reusable assistant scenarios.
      </h1>
      <p class="hero__lede">
        finetuning turns scenario definitions into deterministic or provider-backed OpenAI
        chat fine-tuning JSONL. Start offline, validate every export, then opt into OpenAI
        or Anthropic runs only when a workflow needs model calls.
      </p>
      <p class="hero__annotation">
        Scenarios carry assistant role, tools, personas, goals, and stopping rules. Runtime
        provider choices stay explicit in config files or command flags, with secrets kept in
        environment variables.
      </p>
      <div class="hero__actions">
        <a class="button button--solid" href="/docs/quickstart">Start with the quickstart</a>
        <a class="button button--ghost" href="/docs">Browse the docs</a>
      </div>
    </div>
    <aside class="hero__panel">
      <p class="hero__panel-label">Core commands</p>
      <ul class="hero__signal-list">
        <li>Generate personas from scenario definitions.</li>
        <li>Simulate OpenAI-format chat fine-tuning JSONL.</li>
        <li>Validate and translate datasets before training.</li>
      </ul>
      <div class="hero__terminal">
        <span>$ node dist/cli/index.js generate-personas --config examples/receptionist/scenario.json</span>
        <span>$ node dist/cli/index.js simulate-dataset --mode full_tool_trajectory</span>
        <span>$ node dist/cli/index.js validate-dataset outputs/receptionist-sample.jsonl</span>
        <span>$ node dist/cli/index.js translate-dataset outputs/receptionist-sample.jsonl --target-locale es-ES</span>
      </div>
    </aside>
  </section>

  <section class="shell section-grid">
    <div class="section-heading">
      <p class="section-label">What it solves</p>
      <h2>Fine-tuning examples that are generated, inspected, and validated from one source of truth.</h2>
      <p>
        Ad hoc scripts make training data hard to review. finetuning keeps domain behavior in
        scenario JSON, turns those scenarios into canonical rows, and validates the output shape
        before generated or translated JSONL reaches a training job.
      </p>
    </div>
    <div class="proof-grid">
      {proofPoints.map((item) => (
        <article class="proof-card">
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="shell split-section">
    <div>
      <p class="section-label">Built for</p>
      <h2>Teams that need auditable assistant examples before they send JSONL to training.</h2>
    </div>
    <div class="stack-list">
      {workflows.map((item) => (
        <article class="stack-list__item">
          <p>{item}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="shell capability-band">
    <div class="capability-band__intro">
      <p class="section-label">Dataset model</p>
      <h2>Scenarios, export modes, validation, and provider config stay separate.</h2>
    </div>
    <div class="capability-band__grid">
      <div>
        <p class="capability-title">scenario JSON</p>
        <p>Defines assistant role, business context, persona source, tool inventory, goals, and stopping rules.</p>
      </div>
      <div>
        <p class="capability-title">export modes</p>
        <p>Choose plain chat, tool decision, or full tool trajectory depending on what the example should teach.</p>
      </div>
      <div>
        <p class="capability-title">validation</p>
        <p>Checks message shape, tool-call integrity, result references, duplicate IDs, and dataset summary counts.</p>
      </div>
      <div>
        <p class="capability-title">provider config</p>
        <p>Keeps OpenAI and Anthropic models, base URLs, and API key env vars outside scenario definitions.</p>
      </div>
    </div>
  </section>

  <section class="shell docs-teaser">
    <div class="section-heading">
      <p class="section-label">Docs map</p>
      <h2>Start offline, validate the row shape, then add provider-backed runs deliberately.</h2>
      <p>
        The docs cover setup, deterministic generation, full tool trajectories, validation,
        translation, provider configuration, scenario authoring, examples, architecture, and
        maintenance.
      </p>
    </div>
    <div class="docs-teaser__grid">
      {docs.map((entry) => (
        <a class="docs-teaser__card" href={`/docs/${entry.id}`}>
          <span>{entry.data.category}</span>
          <h3>{entry.data.title}</h3>
          <p>{entry.data.summary ?? entry.data.description}</p>
        </a>
      ))}
    </div>
  </section>
  <section class="shell closing-note">
    <p>
      Use finetuning when scenario-authored behavior, explicit provider boundaries, and
      validator-backed JSONL matter more than one-off dataset scripts.
    </p>
  </section>
</BaseLayout>
