---
import { getCollection } from "astro:content";
import BaseLayout from "zuedocs/layouts/BaseLayout.astro";
import DocsPageActions from "zuedocs/components/DocsPageActions.astro";
import { docCategories, primaryNav, siteConfig } from "../../data/docs";
import "../../styles/docs.css";

const entries = (await getCollection("docs")).sort((a, b) => a.data.order - b.data.order);
const grouped = docCategories.map((category) => ({
  category,
  entries: entries.filter((entry) => entry.data.category === category)
}));
---

<BaseLayout
  title={`${siteConfig.name} Docs`}
  description="Navigate concepts, tutorials, how-to guides, API references, operations, security, migration, and release notes for chat and embedding workflows."
  siteConfig={siteConfig}
  primaryNav={primaryNav}
>
  <section class="shell docs-index-hero">
    <div class="docs-index-hero__head">
      <div>
        <p class="section-label">Documentation</p>
        <h1>Build, inspect, resume, evaluate, and export chat and embedding workflows.</h1>
      </div>
      <DocsPageActions />
    </div>
    <p>
      Start with deterministic offline tutorials, then move through concepts, task guides,
      generated references, operations, and security. Paid, network, model-download, GPU,
      upload, remote-code, and future remote-execution paths stay explicitly gated.
    </p>
  </section>
  <section class="shell docs-index">
    {grouped.map((group) => (
      <section class="docs-index__group">
        <div class="docs-index__group-head">
          <p class="section-label">{group.category}</p>
        </div>
        <div class="docs-index__cards">
          {group.entries.map((entry) => (
            <a class="docs-index__card" href={`/docs/${entry.id}`}>
              <h2>{entry.data.title}</h2>
              <p>{entry.data.description}</p>
              <span>Open guide</span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </section>
</BaseLayout>

<script>
  import "zuedocs/docsEnhancements";
</script>
