{
  "name": "@amxv/finetuning",
  "version": "0.0.0",
  "private": true,
  "description": "Standalone toolkit for generating, validating, and localizing chat fine-tuning datasets.",
  "type": "module",
  "bin": {
    "finetuning": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./core": "./dist/core/index.js",
    "./providers": "./dist/providers/index.js",
    "./simulation": "./dist/simulation/index.js",
    "./translation": "./dist/translation/index.js"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "CONTRIBUTING.md",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "docs:dev": "astro dev",
    "docs:check": "astro check --tsconfig tsconfig.astro.json",
    "docs:build": "astro build",
    "docs:preview": "astro preview",
    "verify:provider-config": "npm run build && node scripts/verify-provider-config.mjs",
    "verify:provider-adapters": "npm run build && node scripts/verify-provider-adapters.mjs",
    "verify:persona-generation": "npm run build && node scripts/verify-persona-generation.mjs",
    "verify:simulation-runners": "npm run build && node scripts/verify-simulation-runners.mjs",
    "verify": "npm run build && node scripts/verify-fixtures.mjs && node scripts/verify-cli.mjs && node scripts/verify-translation.mjs && node scripts/verify-provider-config.mjs && node scripts/verify-provider-adapters.mjs && node scripts/verify-persona-generation.mjs && node scripts/verify-simulation-runners.mjs && node scripts/verify-log-deferment.mjs && node scripts/verify-readme-workflow.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "openai": "^6.45.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/node": "^26.1.0",
    "astro": "^7.0.3",
    "typescript": "^5.5.0"
    ,
    "zuedocs": "^0.1.21"
  }
}
